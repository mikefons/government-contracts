# ─── Required for docker compose (production path) ────────────────────
# Generate a strong secret:  openssl rand -hex 32
SECRET_KEY=
POSTGRES_PASSWORD=
ADMIN_EMAIL=admin@chancery.local
ADMIN_PASSWORD=

# Comma-separated origins allowed to call the API (your real domain in prod)
CORS_ORIGINS=http://localhost:8080

# ─── Optional ─────────────────────────────────────────────────────────
# Agent provider (offline analyst if both unset). Anthropic takes priority.
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_HOST=http://host.docker.internal:11434

# Periodic ingestion
# ENABLE_SCHEDULER=true

# ─── Vercel / serverless ──────────────────────────────────────────────
# SERVERLESS=true        # disables in-proc rate limiter + scheduler, no DB pooling
# RUN_CREATE_ALL=true    # create schema on first request (serverless has no migrate-on-start)
